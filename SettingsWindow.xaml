<Window x:Class="BluetoothLock.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="RSSI 距离锁屏设置" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>

        <!-- RSSI 阈值输入 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="RSSI 阈值 (dBm)，例如 -70"/>
            <TextBox x:Name="RssiThresholdBox" Height="26" Width="120" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- 启用 RSSI 模式复选框 -->
        <CheckBox x:Name="UseRssiCheckBox" Content="启用 RSSI 距离锁屏（低于阈值自动锁屏）"
                  Grid.Row="2" Margin="0,0,0,10"/>

        <!-- 测试连接 + 记录 RSSI -->
        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,10">
            <Button Content="测试连接" Click="TestConnection_Click" Height="30" Width="80"/>
            <Button Content="记录 RSSI" Click="RecordRssi_Click" Height="30" Width="80" Margin="10,0,0,0"/>
            <TextBlock x:Name="RssiResultText" Text="" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 开机自启 -->
        <CheckBox x:Name="AutoStartCheckBox" Content="开机自动启动"
                  Grid.Row="4" Margin="0,0,0,10"
                  Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>

        <!-- 保存设置按钮 -->
        <StackPanel Orientation="Horizontal" Grid.Row="5">
            <Button Content="保存设置" Click="SaveSettings_Click" Height="30" Width="100"/>
            <TextBlock x:Name="SaveStatusText" Text="" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
