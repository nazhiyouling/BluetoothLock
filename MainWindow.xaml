<Window x:Class="BluetoothLock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="蓝牙锁屏监控" Height="250" Width="450"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        ResizeMode="CanMinimize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="蓝牙断开自动锁屏" FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,10" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="选择要监控的设备（如您的手机）："/>
            <ComboBox x:Name="DeviceComboBox" DisplayMemberPath="Name" Height="26"
                      SelectionChanged="DeviceComboBox_SelectionChanged"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
            <Button Content="开始监控" Click="StartStopButton_Click" Height="30" Width="100"/>
            <Button Content="测试连接" Click="TestConnection_Click" Height="30" Width="80" Margin="10,0,0,0"/>
            <CheckBox x:Name="AutoStartCheckBox" Content="开机自动启动" Margin="20,0,0,0"
                      Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Text="未监控" Grid.Row="3"
                   Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,10"/>

        <TextBlock Grid.Row="4" TextWrapping="Wrap" Foreground="DarkGray" FontSize="12"
                   Text="提示：启动后自动最小化到系统托盘。右键托盘图标可退出或重新显示。"/>
    </Grid>
</Window>
