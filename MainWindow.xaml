<Window x:Class="BluetoothLock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="蓝牙锁屏监控 (RSSI测试版)" Height="280" Width="480"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="CanMinimize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="蓝牙 RSSI 测试版" FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,10" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="选择已配对的手机（BLE）："/>
            <ComboBox x:Name="DeviceComboBox" DisplayMemberPath="Name" Height="26"
                      SelectionChanged="DeviceComboBox_SelectionChanged"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
            <Button Content="开始监控" Click="StartStopButton_Click" Height="30" Width="100"/>
            <Button Content="测试连接" Click="TestConnection_Click" Height="30" Width="80" Margin="10,0,0,0"/>
            <!-- 新增：记录 RSSI 按钮 -->
            <Button Content="记录 RSSI" Click="RecordRssi_Click" Height="30" Width="80" Margin="10,0,0,0"/>
            <CheckBox x:Name="AutoStartCheckBox" Content="开机自启" Margin="20,0,0,0"
                      Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Text="未监控" Grid.Row="3"
                   Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,10"/>

        <!-- 显示已记录次数 -->
        <TextBlock x:Name="LogCountText" Grid.Row="4" Text="已记录: 0 次"
                   Foreground="DarkBlue" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" TextWrapping="Wrap" Foreground="DarkGray" FontSize="12"
                   Text="提示：点击“记录 RSSI”保存当前信号值，退出时自动生成 rssi_log.txt。"/>
    </Grid>
</Window>
